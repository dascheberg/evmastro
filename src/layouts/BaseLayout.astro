---
import "../styles/global.css";

const { title = "Event Manager by abg" } = Astro.props;
const current = Astro.url.pathname;
---

<html lang="de" data-theme="light">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
  </head>

  <body class="min-h-screen flex flex-col bg-base-200">
    <!-- NAVBAR -->
    <nav class="navbar bg-base-100 shadow">
      <div class="navbar-start">
        <!-- Hamburger Menü -->
        <div class="dropdown">
          <label tabindex="0" class="btn btn-ghost lg:hidden">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-5 w-5"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M4 6h16M4 12h16M4 18h16"></path>
            </svg>
          </label>

          <ul
            tabindex="0"
            class="menu menu-sm dropdown-content mt-3 z-[1] p-2 shadow bg-base-100 rounded-box w-52"
          >
            <li>
              <a href="/" class={current === "/" ? "font-bold" : ""}
                >Dashboard</a
              >
            </li>

            <li>
              <a
                href="/user"
                class={current.startsWith("/user") ? "font-bold" : ""}
              >
                Events
              </a>
            </li>

            <li>
              <a
                href="/lookups"
                class={current.startsWith("/lookups") ? "font-bold" : ""}
              >
                Lookup-Tabellen
              </a>
            </li>

            <li>
              <a
                href="/import"
                class={current.startsWith("/import") ? "font-bold" : ""}
              >
                Daten-Import
              </a>
            </li>

            <!-- Admin -->
            <li>
              <a
                href="/admin/events"
                class={`text-red-600 ${current.startsWith("/admin") ? "font-bold" : ""}`}
              >
                Admin
              </a>
            </li>
          </ul>
        </div>

        <!-- Logo / Titel -->
        <a class="btn btn-ghost normal-case text-xl">Event Manager by abg</a>
      </div>

      <div class="navbar-center hidden lg:flex">
        <ul class="menu menu-horizontal px-1">
          <li>
            <a href="/" class={current === "/" ? "font-bold" : ""}>Dashboard</a>
          </li>

          <li>
            <a
              href="/user"
              class={current.startsWith("/user") ? "font-bold" : ""}
            >
              Events
            </a>
          </li>

          <li>
            <a
              href="/lookups"
              class={current.startsWith("/lookups") ? "font-bold" : ""}
            >
              Lookup-Tabellen
            </a>
          </li>

          <li>
            <a
              href="/import"
              class={current.startsWith("/import") ? "font-bold" : ""}
            >
              Daten-Import
            </a>
          </li>

          <!-- Admin -->
          <li>
            <a
              href="/admin/events"
              class={`text-red-600 ${current.startsWith("/admin") ? "font-bold" : ""}`}
            >
              Admin
            </a>
          </li>
        </ul>
      </div>

      <div class="navbar-end">
        <!-- Platz für User-Menu / Login, Theme-Switcher etc. -->
      </div>
    </nav>

    <!-- HAUPTINHALT -->
    <main class="flex-1 p-4">
      <slot />
    </main>

    <!-- FOOTER -->
    <footer class="footer footer-center p-4 bg-base-100 text-base-content">
      <aside>
        <p>© {new Date().getFullYear()} – Datenschutzerklärung – Impressum</p>
      </aside>
    </footer>
  </body>
</html>
