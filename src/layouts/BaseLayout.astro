---
import "../styles/global.css";
import { auth } from "../lib/auth";

const { title = "Event Manager by abg" } = Astro.props;
const current = Astro.url.pathname;

const session = await auth.api.getSession({
  headers: Astro.request.headers,
});

const isLoggedIn = !!session;
const isAdmin = current.startsWith("/admin");
---

<html lang="de" data-theme="light">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
  </head>

  <body class="min-h-screen flex flex-col bg-base-200">
    <nav class="navbar bg-base-100 shadow">
      <div class="navbar-start">
        <div class="dropdown">
          <label tabindex="0" class="btn btn-ghost lg:hidden">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-5 w-5"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M4 6h16M4 12h16M4 18h16"></path>
            </svg>
          </label>
          <ul
            tabindex="0"
            class="menu menu-sm dropdown-content mt-3 z-[1] p-2 shadow bg-base-100 rounded-box w-52"
          >
            <li class="menu-title"><span>Bereich</span></li>
            <li>
              <a href="/" class={current === "/" ? "font-bold" : ""}
                >Dashboard</a
              >
            </li>
            <li>
              <a
                href="/user"
                class={current.startsWith("/user") ? "font-bold" : ""}
                >Veranstaltungen</a
              >
            </li>
            <li>
              <a href="/hilfe" class={current === "/hilfe" ? "font-bold" : ""}
                >Hilfe</a
              >
            </li>
            {
              isLoggedIn && (
                <>
                  <li class="menu-title mt-2">
                    <span class="text-red-600">Admin</span>
                  </li>
                  <li>
                    <a
                      href="/admin/events"
                      class={`text-red-600 ${current === "/admin/events" ? "font-bold" : ""}`}
                    >
                      Veranstaltungen verwalten
                    </a>
                  </li>
                  <li>
                    <a
                      href="/admin/lookups"
                      class={`text-red-600 ${current === "/admin/lookups" ? "font-bold" : ""}`}
                    >
                      Lookup-Tabellen
                    </a>
                  </li>
                  <li>
                    <a
                      href="/admin/import"
                      class={`text-red-600 ${current === "/admin/import" ? "font-bold" : ""}`}
                    >
                      Daten-Import
                    </a>
                  </li>
                  <li>
                    <a
                      href="/admin/imports"
                      class={`text-red-600 ${current === "/admin/imports" ? "font-bold" : ""}`}
                    >
                      Import-Übersicht
                    </a>
                  </li>
                  <li>
                    <a
                      href="/admin/api-info"
                      class={`text-red-600 ${current === "/admin/api-info" ? "font-bold" : ""}`}
                    >
                      API-Information
                    </a>
                  </li>
                  <li>
                    <a
                      href="/admin/users"
                      class={`text-red-600 ${current === "/admin/users" ? "font-bold" : ""}`}
                    >
                      Admin-Verwaltung
                    </a>
                  </li>
                  <li>
                    <a
                      href="/admin/dokumentation"
                      class={`text-red-600 ${current === "/admin/dokumentation" ? "font-bold" : ""}`}
                    >
                      Dokumentation
                    </a>
                  </li>
                </>
              )
            }
          </ul>
        </div>
        <a href="/" class="btn btn-ghost normal-case text-xl"
          >Event Manager by abg</a
        >
      </div>

      <div class="navbar-center hidden lg:flex">
        <ul class="menu menu-horizontal px-1 gap-1">
          <li>
            <a href="/" class={current === "/" ? "font-bold" : ""}>Dashboard</a>
          </li>
          <li>
            <a
              href="/user"
              class={current.startsWith("/user") ? "font-bold" : ""}
              >Veranstaltungen</a
            >
          </li>
          <li>
            <a href="/hilfe" class={current === "/hilfe" ? "font-bold" : ""}
              >Hilfe</a
            >
          </li>
          {
            isLoggedIn && (
              <li>
                <details>
                  <summary
                    class={`text-red-600 font-semibold ${isAdmin ? "font-bold" : ""}`}
                  >
                    Admin
                  </summary>
                  <ul class="bg-base-100 rounded-box shadow z-[1] w-56 p-2">
                    <li>
                      <a
                        href="/admin/events"
                        class={`text-red-600 ${current === "/admin/events" ? "font-bold" : ""}`}
                      >
                        Veranstaltungen verwalten
                      </a>
                    </li>
                    <li>
                      <a
                        href="/admin/lookups"
                        class={`text-red-600 ${current === "/admin/lookups" ? "font-bold" : ""}`}
                      >
                        Lookup-Tabellen
                      </a>
                    </li>
                    <li>
                      <a
                        href="/admin/import"
                        class={`text-red-600 ${current === "/admin/import" ? "font-bold" : ""}`}
                      >
                        Daten-Import
                      </a>
                    </li>
                    <li>
                      <a
                        href="/admin/imports"
                        class={`text-red-600 ${current === "/admin/imports" ? "font-bold" : ""}`}
                      >
                        Import-Übersicht
                      </a>
                    </li>
                    <li>
                      <a
                        href="/admin/api-info"
                        class={`text-red-600 ${current === "/admin/api-info" ? "font-bold" : ""}`}
                      >
                        API-Information
                      </a>
                    </li>
                    <li>
                      <a
                        href="/admin/users"
                        class={`text-red-600 ${current === "/admin/users" ? "font-bold" : ""}`}
                      >
                        Admin-Verwaltung
                      </a>
                    </li>
                    <li>
                      <a
                        href="/admin/dokumentation"
                        class={`text-red-600 ${current === "/admin/dokumentation" ? "font-bold" : ""}`}
                      >
                        Dokumentation
                      </a>
                    </li>
                  </ul>
                </details>
              </li>
            )
          }
        </ul>
      </div>

      <div class="navbar-end gap-2">
        {
          isLoggedIn ? (
            <>
              <span class="text-sm text-gray-500 hidden md:block">
                {session.user.name || session.user.email}
              </span>
              <button id="logoutBtn" class="btn btn-sm btn-ghost text-red-600">
                Logout
              </button>
            </>
          ) : (
            <a href="/login" class="btn btn-sm btn-outline">
              Admin-Login
            </a>
          )
        }
      </div>
    </nav>

    <main class="flex-1 p-4">
      <slot />
    </main>

    <footer class="footer footer-center p-4 bg-base-100 text-base-content">
      <aside>
        <p>© {new Date().getFullYear()} – Datenschutzerklärung – Impressum</p>
      </aside>
    </footer>
  </body>
</html>
<script>
  document.getElementById("logoutBtn")?.addEventListener("click", async () => {
    await fetch("/api/auth/logout", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
    });
    window.location.href = "/";
  });
</script>
