---
// src/pages/abonnieren.astro — komplett ersetzen
export const prerender = false;

import BaseLayout from "../layouts/BaseLayout.astro";
import { db } from "../db";
import { organizers, locations } from "../db/schema";

const allOrganizers = await db
  .select()
  .from(organizers)
  .orderBy(organizers.name);
const allLocations = await db.select().from(locations).orderBy(locations.name);
---

<BaseLayout title="Terminbenachrichtigungen">
  <div class="max-w-2xl mx-auto space-y-6">
    <!-- Header -->
    <div class="flex items-center gap-3">
      <button id="backBtn" class="btn btn-ghost btn-sm px-2" title="Zurück">
        ← Zurück
      </button>
      <div>
        <h1 class="text-2xl font-bold">🔔 Terminbenachrichtigungen</h1>
        <p class="text-sm text-gray-500">
          Erhalte eine E-Mail, wenn Veranstaltungen deiner Wahl angelegt,
          geändert oder abgesagt werden.
        </p>
      </div>
    </div>

    <!-- Meldungen -->
    <div id="successMsg" class="hidden alert alert-success">
      <span>✅ Anmeldung erfolgreich! Du wirst ab sofort benachrichtigt.</span>
    </div>
    <div id="errorMsg" class="hidden alert alert-error">
      <span id="errorText"></span>
    </div>

    <!-- Karte -->
    <div class="card bg-base-100 shadow">
      <div class="card-body space-y-5">
        <!-- Name + E-Mail -->
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <label class="form-control w-full">
            <span class="label-text font-semibold mb-1">Dein Name</span>
            <input
              id="name"
              type="text"
              placeholder="Max Mustermann"
              class="input input-bordered w-full"
            />
          </label>
          <label class="form-control w-full">
            <span class="label-text font-semibold mb-1">E-Mail-Adresse</span>
            <input
              id="email"
              type="email"
              placeholder="max@beispiel.de"
              class="input input-bordered w-full"
            />
          </label>
        </div>

        <!-- Auswahl-Tabellen nebeneinander -->
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
          <!-- Veranstalter -->
          <div>
            <p class="font-semibold mb-1">🏢 Veranstalter</p>
            <p class="text-xs text-gray-500 mb-2">
              Benachrichtigung bei allen Terminen dieser Veranstalter.
            </p>
            <div class="border rounded-lg overflow-hidden bg-base-100">
              <table class="table table-sm w-full">
                <tbody>
                  {
                    allOrganizers.map((o) => (
                      <tr class="hover cursor-pointer org-row">
                        <td class="w-10">
                          <input
                            type="checkbox"
                            class="checkbox checkbox-sm checkbox-primary org-check"
                            value={String(o.id)}
                          />
                        </td>
                        <td class="text-sm">{o.name}</td>
                      </tr>
                    ))
                  }
                </tbody>
              </table>
            </div>
          </div>

          <!-- Orte -->
          <div>
            <p class="font-semibold mb-1">📍 Veranstaltungsorte</p>
            <p class="text-xs text-gray-500 mb-2">
              Benachrichtigung bei allen Terminen an diesen Orten.
            </p>
            <div class="border rounded-lg overflow-hidden bg-base-100">
              <table class="table table-sm w-full">
                <tbody>
                  {
                    allLocations.map((l) => (
                      <tr class="hover cursor-pointer loc-row">
                        <td class="w-10">
                          <input
                            type="checkbox"
                            class="checkbox checkbox-sm checkbox-secondary loc-check"
                            value={String(l.id)}
                          />
                        </td>
                        <td class="text-sm">{l.name}</td>
                      </tr>
                    ))
                  }
                </tbody>
              </table>
            </div>
          </div>
        </div>

        <!-- Button -->
        <button id="subscribeBtn" class="btn btn-primary w-full">
          Jetzt anmelden
        </button>

        <p class="text-xs text-gray-400 text-center">
          Du kannst dich jederzeit per Link in der E-Mail wieder abmelden.
        </p>
      </div>
    </div>
  </div>
</BaseLayout>

<script>
  // Zurück-Button
  document.getElementById("backBtn")?.addEventListener("click", () => {
    if (history.length > 1) history.back();
    else window.location.href = "/";
  });

  // Klick auf ganze Zeile togglet Checkbox
  document.querySelectorAll(".org-row, .loc-row").forEach((row) => {
    row.addEventListener("click", (e) => {
      const cb = row.querySelector("input[type=checkbox]") as HTMLInputElement;
      if (cb && e.target !== cb) cb.checked = !cb.checked;
    });
  });

  // Absenden
  document
    .getElementById("subscribeBtn")
    ?.addEventListener("click", async () => {
      const name = (
        document.getElementById("name") as HTMLInputElement
      ).value.trim();
      const email = (
        document.getElementById("email") as HTMLInputElement
      ).value.trim();

      const organizerIds = [
        ...document.querySelectorAll(".org-check:checked"),
      ].map((el) => Number((el as HTMLInputElement).value));
      const locationIds = [
        ...document.querySelectorAll(".loc-check:checked"),
      ].map((el) => Number((el as HTMLInputElement).value));

      const errDiv = document.getElementById("errorMsg")!;
      const errText = document.getElementById("errorText")!;
      const succDiv = document.getElementById("successMsg")!;
      const btn = document.getElementById("subscribeBtn") as HTMLButtonElement;

      errDiv.classList.add("hidden");
      succDiv.classList.add("hidden");

      const res = await fetch("/api/subscribers", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ name, email, organizerIds, locationIds }),
      });

      const data = await res.json();

      if (!res.ok) {
        errText.textContent = data.error ?? "Ein Fehler ist aufgetreten.";
        errDiv.classList.remove("hidden");
        return;
      }

      succDiv.classList.remove("hidden");
      btn.disabled = true;

      // Nach 3 Sekunden zurück
      setTimeout(() => {
        if (history.length > 1) history.back();
        else window.location.href = "/";
      }, 3000);
    });
</script>
