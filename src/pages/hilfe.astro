---
import BaseLayout from "../layouts/BaseLayout.astro";
import { readFile } from "node:fs/promises";
import { marked } from "marked";

const mdFile = new URL("../content/hilfe.md", import.meta.url);
const md = await readFile(mdFile, "utf-8");
const html = marked.parse(md) as string;
---

<BaseLayout title="Hilfe">
  <div class="max-w-3xl mx-auto py-8 px-4">
    <div
      class="hilfe-prose prose prose-green max-w-none bg-white rounded-xl border p-8 shadow-sm"
      set:html={html}
    />
  </div>
</BaseLayout>

<style is:global>
  .hilfe-prose h1 {
    color: #2c5f2d;
    font-size: 1.8rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
  }

  .hilfe-prose h2 {
    color: #2c5f2d;
    font-size: 1.3rem;
    font-weight: 600;
    margin-top: 1.8rem;
    margin-bottom: 0.6rem;
    border-bottom: 2px solid #97bc62;
    padding-bottom: 0.4rem;
  }
  .hilfe-prose h3 {
    color: #1a3b1b;
    font-size: 1.1rem;
    font-weight: 600;
    margin-top: 1.2rem;
    margin-bottom: 0.4rem;
  }
  .hilfe-prose h4 {
    color: #1a3b1b;
    font-size: 1rem;
    font-weight: 600;
    margin-top: 1rem;
  }
  .hilfe-prose p {
    margin-bottom: 1rem;
    line-height: 1.6;
  }

  .hilfe-prose ul,
  .hilfe-prose ol {
    margin-bottom: 1rem;
    margin-left: 1.5rem;
  }
  .hilfe-prose li {
    margin-bottom: 0.4rem;
    line-height: 1.5;
  }
  .hilfe-prose code {
    background: #f1f5f1;
    padding: 1px 5px;
    border-radius: 4px;
    font-size: 0.85em;
    color: #2c5f2d;
  }
  .hilfe-prose pre {
    background: #f1f5f1;
    padding: 1rem;
    border-radius: 8px;
    border-left: 3px solid #97bc62;
    overflow-x: auto;
    margin-bottom: 1rem;
  }
  .hilfe-prose pre code {
    background: none;
    padding: 0;
    color: inherit;
  }
  .hilfe-prose blockquote {
    border-left: 3px solid #97bc62;
    background: #f5f5f5;
    padding: 0.5rem 1rem;
    border-radius: 0 8px 8px 0;
    color: #64748b;
    font-style: italic;
    margin: 1rem 0;
  }
  .hilfe-prose a {
    color: #2c5f2d;
    text-decoration: underline;
  }
  .hilfe-prose a:hover {
    color: #1a3b1b;
  }
  .hilfe-prose hr {
    border-color: #97bc62;
    margin: 2rem 0;
  }
  .hilfe-prose table {
    border-collapse: collapse;
    width: 100%;
    margin: 1rem 0;
  }
  .hilfe-prose th,
  .hilfe-prose td {
    border: 1px solid #ddd;
    padding: 0.75rem;
    text-align: left;
  }
  .hilfe-prose th {
    background: #f1f5f1;
    color: #2c5f2d;
    font-weight: 600;
  }
</style>
